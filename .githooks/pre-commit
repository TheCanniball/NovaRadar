#!/usr/bin/env pwsh
# Nova Radar Pre-Commit Hook
# Runs Play Protect safety check before each commit.
# To install: git config core.hooksPath .githooks

Write-Host "=== Nova Radar Pre-Commit: Running Play Protect check ===" -ForegroundColor Cyan

$scriptPath = Join-Path $PSScriptRoot "..\scripts\check-play-protect.ps1"
& $scriptPath

if ($LASTEXITCODE -ne 0) {
    Write-Host "=== COMMIT BLOCKED: Play Protect check found issues ===" -ForegroundColor Red
    Write-Host "Review the warnings above. To commit anyway, use: git commit --no-verify" -ForegroundColor Yellow
    exit 1
}

Write-Host "=== Pre-commit check passed. Proceeding... ===" -ForegroundColor Green
exit 0
